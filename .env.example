# Copy to .env and adjust. .env is gitignored.

# --- Lean datastores (Phase 0) ---
REDIS_PORT=6379

NEO4J_USER=neo4j
NEO4J_PASSWORD=rmsai_dev_pw
NEO4J_HTTP_PORT=7474
NEO4J_BOLT_PORT=7687

QDRANT_HTTP_PORT=6333
QDRANT_GRPC_PORT=6334

# --- Telemetry broker (Phase 1) ---
MQTT_PORT=1883

# --- LLM serving (Phase 2/4/6) ---
OLLAMA_PORT=11434
# Orchestrator LLM: echo (deterministic, offline) | ollama (self-hosted local model)
LLM_PROVIDER=echo
OLLAMA_URL=http://localhost:11434
LLM_MODEL=llama3.2

# --- Embeddings (vector RAG + episodic memory) ---
# hashing (offline, deterministic) | bge (real, needs `uv sync --extra rag`) | auto
EMBEDDER=hashing
BGE_MODEL=BAAI/bge-small-en-v1.5

# Episodic recall: condition free-text answers on recalled past Q&A. Off by default (answers stay
# grounded in the live KB + the current conversation only). Set true to enable cross-session recall.
# EPISODIC_RECALL=false

# --- De-identification (before any model call) ---
DEID_BACKEND=regex            # regex (offline) | presidio (NLP) | auto (presidio, fall back to regex)
DEID_SPACY_MODEL=en_core_web_lg   # spaCy NER model for presidio (or en_core_web_sm for a light install)

# --- Voice STT/TTS (real audio path via the LiveKit agent) ---
STT_BACKEND=stub     # stub | whisper | elevenlabs
TTS_BACKEND=stub     # stub | piper | elevenlabs
WHISPER_MODEL=base.en          # faster-whisper model, e.g. tiny.en (English-only, fastest)
STT_LANGUAGE=en                # force STT language (ISO 639-1); blank or "auto" = auto-detect
# STT_INITIAL_PROMPT=          # override Whisper vocab biasing (defaults to clinical terms, G15)
PIPER_VOICE_PATH=

# ElevenLabs (cloud STT "Scribe" + TTS) — accuracy/latency benchmarking on SYNTHETIC data ONLY.
# Audio/text leaves this host to a third party; NEVER use with real PHI (hard rules #4/#5).
# ELEVENLABS_API_KEY=
# ELEVENLABS_VOICE_ID=pNInz6obpgDQGcFmaJgB   # premade voice ("Adam"); free-tier usable. Library/
#   some premade voices (e.g. "Rachel") require a paid plan (402 paid_plan_required).
# ELEVENLABS_TTS_MODEL=eleven_flash_v2_5     # low-latency TTS model
# ELEVENLABS_STT_MODEL=scribe_v1
# ELEVENLABS_TTS_SAMPLE_RATE=22050           # 16000 | 22050 | 24000 | 44100

# LiveKit — self-hosted (ws://localhost:7880) OR LiveKit Cloud (wss://<project>.livekit.cloud).
# Used for inbound + outbound voice. Get key/secret from the LiveKit Cloud dashboard.
LIVEKIT_URL=ws://localhost:7880
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=
LIVEKIT_SIP_TRUNK_ID=          # outbound SIP trunk id (Cloud Telephony) for cli.outbound --caller livekit
LIVEKIT_SIP_ROOM=rmsai-outbound

# --- Voice / media (Phase 5+) ---
LIVEKIT_PORT=7880
LIVEKIT_RTC_PORT=7881

# --- POC behaviour defaults (see common/config.py) ---
FP_SUPPRESS_MIN_CONFIDENCE=0.80
LOW_CONFIDENCE_CAVEAT=0.60
INBOUND_AUTH_PIN=1234

# --- Outbound calling / texting (Phase 7) ---
OUTBOUND_ENABLED=false
OUTBOUND_CALL_NUMBER=
OUTBOUND_FROM=
OUTBOUND_MIN_CRITICALITY=High
OUTBOUND_MAX_RETRIES=2
OUTBOUND_RETRY_DELAY_S=30

# Real SMS delivery (only needed for `cli.outbound --channel text --notifier twilio`)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
# (the SMS "from" number uses OUTBOUND_FROM above)

# ECG strip plots — producer renders each event ECG lead to {PLOT_DIR}/<event_id>.png (gitignored)
# ECG_PLOT_ENABLED=true
# PLOT_DIR=data/plots
